{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv sync)",
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run uvicorn:*)",
      "Bash(make:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(docker compose:*)",
      "Bash(docker-compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(docker compose down:*)",
      "Bash(docker rm:*)",
      "Bash(docker volume rm:*)"
    ],
    "deny": []
  }
}
