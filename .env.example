# Environment Configuration Example

# Application Settings
APP_ENV=development
PROJECT_NAME="Web Assistant"
VERSION=1.0.0
DEBUG=true

# API Settings
API_V1_STR=/api/v1

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# Langfuse Settings
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST=https://cloud.langfuse.com

# ═══════════════════════════════════════════════════════════════════════════════════════════════
# LLM Settings — ONE knob. MODEL is a "provider:model" string; the provider is inferred from the
# prefix and dispatched by LangChain's init_chat_model. Set only the API key of the provider you use;
# LangChain reads it from the environment. Startup builds MODEL once and fails fast with a clear
# message if its key is missing.
#
#   MODEL=anthropic:claude-sonnet-5      → needs ANTHROPIC_API_KEY            (prompt caching auto-on)
#   MODEL=openai:gpt-4o                  → needs OPENAI_API_KEY
#   MODEL=azure_openai:<deployment>      → needs AZURE_OPENAI_* (endpoint + key + version)
# ═══════════════════════════════════════════════════════════════════════════════════════════════
MODEL=anthropic:claude-sonnet-5
MODEL_MAX_TOKENS=8192           # output cap (Anthropic requires one; harmless on OpenAI/Azure)
MODEL_CALL_LIMIT=40             # per-turn safety cap (agent ends gracefully at the cap)

# ── Provider API keys ── set ONLY the one your MODEL uses; leave the rest blank.
ANTHROPIC_API_KEY="your-anthropic-api-key"
OPENAI_API_KEY="your-openai-api-key"

# ── Azure OpenAI ── only when MODEL=azure_openai:<deployment>. The part after the ":" in MODEL is the
# deployment NAME you created in the Azure portal (not a base model id). Endpoint + version are read
# from here (Azure needs them in addition to the key).
AZURE_OPENAI_ENDPOINT="https://<resource>.openai.azure.com"
AZURE_OPENAI_API_KEY="your-azure-openai-api-key"
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Utility (cheap) model ── low-stakes sub-flows (file descriptions, safety check, research
# internals). Blank = reuse MODEL. Same "provider:model" format, e.g. openai:gpt-5-nano.
UTILITY_MODEL=

# ── Long-term memory (mem0) + embeddings ── Embeddings are a SEPARATE provider because Anthropic has
# no embedding model. EMBEDDINGS_MODEL is a "provider:model" string (e.g. openai:text-embedding-3-small);
# blank = auto-resolve from whichever of OpenAI/Azure has a key, else memory turns off with a startup
# warning. Set LONG_TERM_MEMORY_ENABLED=false to disable it outright.
LONG_TERM_MEMORY_ENABLED=true
EMBEDDINGS_MODEL=              # e.g. openai:text-embedding-3-small  (blank = auto/off)
# For an Azure embeddings model: the deployment name (endpoint/key/version reuse AZURE_OPENAI_* above).
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="your-embeddings-deployment-name"

# JWT Settings
JWT_SECRET_KEY="your-jwt-secret-key"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# Database Settings
POSTGRES_HOST=db
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PORT=5432
POSTGRES_PASSWORD=mypassword
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Rate Limiting Settings
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_LOGIN="100 per minute"

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console


# MCP
MCP_ENABLED=true
MCP_SERVER_PORT=7001
MCP_HOSTNAMES_CSV=mcp:7001

# Data Agent granted folders (served read-only via a per-session deepagents FilesystemBackend).
# Comma-separated host roots that may be granted (read-only) to the agent's file tools.
# Empty = folder grants are DISABLED (secure default). Never include folders with secrets.
# Supports ~ and env-var expansion (e.g. ~, $HOME/agent-data) — resolves to the home of the
# OS user running the server, so avoid hardcoding a username. A drive root (C:/) allows the
# whole drive and defeats the sandbox — don't do that outside single-user local dev.
SANDBOX_ALLOWED_ROOTS=
# SANDBOX_ENABLED=true
# Virtual path the granted folder is exposed at (agent addresses files under this prefix).
# SANDBOX_MOUNT_PATH=/workspace

# Secret used to encrypt persisted credentials at rest (e.g. a bound database password).
# Empty = secure default: passwords are NOT persisted; the user re-enters them per session.
# Any non-empty passphrase works (a Fernet key is derived from it). Use a KMS/secret manager
# in production, not a committed value.
ENCRYPTION_KEY=

# Vetted base URL a user may fetch skills from (single allow-listed host). Empty = fetch disabled.
SKILL_REGISTRY_URL=
