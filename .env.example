# Environment Configuration Example

# Application Settings
APP_ENV=development
PROJECT_NAME="Web Assistant"
VERSION=1.0.0
DEBUG=true

# API Settings
API_V1_STR=/api/v1

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# Langfuse Settings
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM Settings
# Chat-model provider for the agents: "anthropic" (Claude Sonnet 5, prompt caching on) or "openai".
LLM_PROVIDER=anthropic
OPENAI_API_KEY="your-llm-api-key" # e.g. OpenAI API key
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_LLM_TEMPERATURE=0.2

# Anthropic (used when LLM_PROVIDER=anthropic). Long-term memory + evals still use OpenAI.
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MAX_TOKENS=8192
# Prompt caching (Anthropic only): prefix-match caching of the stable system prompt + tools.
PROMPT_CACHING_ENABLED=true
PROMPT_CACHE_TTL=5m  # "5m" or "1h"

# JWT Settings
JWT_SECRET_KEY="your-jwt-secret-key"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# Database Settings
POSTGRES_HOST=db
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PORT=5432
POSTGRES_PASSWORD=mypassword
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Rate Limiting Settings
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_LOGIN="100 per minute"

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console


# MCP
MCP_ENABLED=true
MCP_SERVER_PORT=7001
MCP_HOSTNAMES_CSV=mcp:7001

# Data Agent granted folders (served read-only via a per-session deepagents FilesystemBackend).
# Comma-separated host roots that may be granted (read-only) to the agent's file tools.
# Empty = folder grants are DISABLED (secure default). Never include folders with secrets.
# Supports ~ and env-var expansion (e.g. ~, $HOME/agent-data) — resolves to the home of the
# OS user running the server, so avoid hardcoding a username. A drive root (C:/) allows the
# whole drive and defeats the sandbox — don't do that outside single-user local dev.
SANDBOX_ALLOWED_ROOTS=
# SANDBOX_ENABLED=true
# Virtual path the granted folder is exposed at (agent addresses files under this prefix).
# SANDBOX_MOUNT_PATH=/workspace

# Secret used to encrypt persisted credentials at rest (e.g. a bound database password).
# Empty = secure default: passwords are NOT persisted; the user re-enters them per session.
# Any non-empty passphrase works (a Fernet key is derived from it). Use a KMS/secret manager
# in production, not a committed value.
ENCRYPTION_KEY=

# Vetted base URL a user may fetch skills from (single allow-listed host). Empty = fetch disabled.
SKILL_REGISTRY_URL=
